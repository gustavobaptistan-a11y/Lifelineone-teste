# ======================================================
# LIFELINE BOT - .gitignore
# ======================================================

# ------------------------------------------------------
# Ambiente Virtual
# ------------------------------------------------------
.venv/
venv/
env/

# ------------------------------------------------------
# Python
# ------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# Cache
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Logs
*.log

# ------------------------------------------------------
# Variáveis de Ambiente
# ------------------------------------------------------
.env
.env.*
!.env.example

# ------------------------------------------------------
# Credenciais e Segredos
# ------------------------------------------------------
app/config/credentials.json
app/config/credentials.json.json
app/config/token.json
app/config/*.pem
app/config/*.key
app/config/*.crt

# ------------------------------------------------------
# Backups
# ------------------------------------------------------
config_backup/
*.bak
*.backup

# ------------------------------------------------------
# Banco de Dados
# ------------------------------------------------------
*.db
*.sqlite
*.sqlite3

# ------------------------------------------------------
# Arquivos Temporários
# ------------------------------------------------------
*.tmp
*.temp
*.cache

# ------------------------------------------------------
# Executáveis
# ------------------------------------------------------
*.exe

# Caso o ngrok fique dentro do projeto
ngrok.exe

# ------------------------------------------------------
# IDEs
# ------------------------------------------------------
.vscode/
.idea/

# ------------------------------------------------------
# Sistema Operacional
# ------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------
# Testes Locais
# ------------------------------------------------------
testar_rotas_evolution.py

# ------------------------------------------------------
# Build e Distribuição
# ------------------------------------------------------
build/
dist/
*.egg-info/

# ------------------------------------------------------
# Arquivos Sensíveis
# ------------------------------------------------------
sessions.json